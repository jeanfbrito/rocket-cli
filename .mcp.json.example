{
  "mcpServers": {
    "rocketchat-test": {
      "command": "node",
      "args": ["dist/cli.js", "serve"],
      "env": {
        "ROCKET_CLI_PROFILE": "test"
      }
    },
    "rocketchat-work": {
      "command": "node",
      "args": ["dist/cli.js", "serve"],
      "env": {
        "ROCKET_CLI_PROFILE": "work"
      }
    }
  }
}
