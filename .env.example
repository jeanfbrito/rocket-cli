ROCKETCHAT_URL=
ROCKETCHAT_TOKEN=
ROCKETCHAT_USER_ID=
ROCKET_CLI_DB=
ROCKET_CLI_SYNC_TTL_SECONDS=60
ROCKET_CLI_BACKFILL_LIMIT=500
# Cache custom-emoji images (true/false). false = metadata only, no image bytes.
ROCKET_CLI_EMOJI_IMAGES=true
# Select a named profile from ~/.config/rocket-cli/profiles.json instead of the
# vars above (equivalent to the global --profile flag). Handy for MCP server
# registrations where passing CLI flags is awkward. Leave blank for env-only use.
ROCKET_CLI_PROFILE=
